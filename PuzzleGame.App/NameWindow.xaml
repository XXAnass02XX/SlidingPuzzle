<Window x:Class="PuzzleGame.App.NameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Sliding Puzzle" Height="300" Width="360"
        WindowStartupLocation="CenterScreen">
    <StackPanel VerticalAlignment="Top" Margin="40,30,40,0">
        <TextBlock Text="Enter your name:" FontSize="16" Margin="0,0,0,8"/>
        <TextBox Name="NameBox" FontSize="16" Padding="6" Margin="0,0,0,16"/>
        <Button Name="StartButton" Content="Start" FontSize="16"
                Height="40" IsDefault="True"
                Click="StartButton_Click"
                MouseRightButtonUp="StartButton_Click"/>
        <TextBlock Text="Puzzle Game" FontSize="22" Margin="0,80,0,8"/>
    </StackPanel>
</Window>
